# Copy to .env and fill in.

# LLM for translation/lookup — set ONE of these keys (or both; anthropic wins
# unless THORSPEAK_LLM_PROVIDER says otherwise).
ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...

# THORSPEAK_LLM_PROVIDER=auto            # auto | anthropic | openrouter
# THORSPEAK_CLAUDE_MODEL=claude-haiku-4-5
# THORSPEAK_OPENROUTER_MODEL=anthropic/claude-haiku-4.5
# Any OpenAI-compatible endpoint works, e.g. Ollama:
# THORSPEAK_OPENROUTER_BASE_URL=http://localhost:11434/v1

THORSPEAK_PORT=8737
THORSPEAK_CACHE_DIR=~/.cache/thorspeak
THORSPEAK_AUDIO_CACHE_MAX_MB=2048
# Optional voice overrides, e.g.:
# THORSPEAK_DEFAULT_VOICES=ja:ja-JP-KeitaNeural,en:en-US-GuyNeural,th:th-TH-NiwatNeural
