# Copy to .env and fill in.
ANTHROPIC_API_KEY=sk-ant-...
THORSPEAK_PORT=8737
THORSPEAK_CACHE_DIR=~/.cache/thorspeak
THORSPEAK_AUDIO_CACHE_MAX_MB=2048
# Optional voice overrides, e.g.:
# THORSPEAK_DEFAULT_VOICES=ja:ja-JP-KeitaNeural,en:en-US-GuyNeural,th:th-TH-NiwatNeural
# THORSPEAK_CLAUDE_MODEL=claude-haiku-4-5
